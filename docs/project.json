{
  "name": "docs",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "targets": {
    "docs-build": {
      "executor": "nx:run-commands",
      "options": { "command": "uv run --group docs mkdocs build --strict" }
    },
    "docs-serve": {
      "executor": "nx:run-commands",
      "options": { "command": "uv run --group docs mkdocs serve" }
    }
  }
}
