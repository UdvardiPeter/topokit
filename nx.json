{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "plugins": [{ "plugin": "@nxlv/python", "options": { "packageManager": "uv" } }],
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [
      "{workspaceRoot}/pyproject.toml",
      "{workspaceRoot}/uv.lock",
      "{workspaceRoot}/nx.json"
    ]
  },
  "targetDefaults": {
    "lint": { "cache": true, "inputs": ["default"] },
    "typecheck": { "cache": true, "inputs": ["default"] },
    "boundaries": { "cache": true, "inputs": ["default"] },
    "test": { "cache": true, "inputs": ["default"] },
    "test-fd": { "cache": true, "inputs": ["default"] },
    "build": { "cache": true, "inputs": ["default"], "outputs": ["{projectRoot}/dist"] },
    "docs-build": { "cache": true, "inputs": ["default"], "outputs": ["{workspaceRoot}/site"] }
  }
}
